/* app.wxss - 全局样式 */

/* 全局重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #4A90E2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background-color: #357ABD;
}

.btn-secondary {
  background-color: #ffffff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-secondary:active {
  background-color: #f0f7ff;
}

/* 文字样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: #666666;
}

.text-muted {
  color: #999999;
  font-size: 24rpx;
}

/* 间距 */
.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
