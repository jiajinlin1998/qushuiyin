/* components/canvas-selector/canvas-selector.wxss */

.canvas-selector {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 模式切换 */
.mode-switcher {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
  width: 100%;
}

.mode-btn {
  padding: 16rpx 32rpx;
  background-color: #f0f0f0;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  flex: 1;
  max-width: 240rpx;
}

.mode-btn.active {
  background-color: #4A90E2;
  color: #ffffff;
}

/* Canvas容器 */
.canvas-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

.SelectorCanvas {
  width: 100%;
  height: 600rpx;
  background-color: #ffffff;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  text-align: center;
  flex: 1;
  max-width: 200rpx;
}

.cancel-btn {
  background-color: #ff4d4f;
  color: #ffffff;
}

.undo-btn {
  background-color: #faad14;
  color: #ffffff;
}

.confirm-btn {
  background-color: #52c41a;
  color: #ffffff;
}
