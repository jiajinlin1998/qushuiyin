/* pages/image-process/image-process.wxss */

.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 隐藏的处理Canvas */
.processCanvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 300px;
  height: 300px;
  pointer-events: none;
  opacity: 0;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  color: #999999;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.step.active .step-number {
  background-color: #4A90E2;
  color: #ffffff;
}

.step-text {
  font-size: 22rpx;
  color: #999999;
}

.step.active .step-text {
  color: #4A90E2;
  font-weight: 500;
}

.step-line {
  width: 100rpx;
  height: 4rpx;
  background-color: #e0e0e0;
  margin: 0 10rpx 30rpx;
}

.step-line.active {
  background-color: #4A90E2;
}

/* 步骤内容 */
.step-content {
  flex: 1;
}

.step-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 提示信息 */
.tip-card {
  background-color: #fff7e6;
  border-left: 6rpx solid #faad14;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 30rpx;
  display: flex;
  align-items: center;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* 处理中 */
.processing-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 500rpx;
}

.processing-animation {
  text-align: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #4A90E2;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.processing-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.processing-tip {
  font-size: 24rpx;
  color: #999999;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-buttons .btn-secondary,
.action-buttons .btn-primary {
  flex: 1;
  margin: 0;
}
