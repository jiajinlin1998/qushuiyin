/* pages/index/index.wxss */

/* 头部Banner区域 */
.header {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA3F5 100%);
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  color: #ffffff;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 功能区 */
.feature-section {
  padding: 40rpx 30rpx;
}

.feature-section .section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #4A90E2;
}

/* 功能卡片 */
.feature-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-card {
  width: 48%;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
}

.feature-card .card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.feature-card .card-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 快速上传区域 */
.upload-section {
  background-color: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

.upload-section .section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.upload-buttons {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.upload-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
}

.upload-btn-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.upload-btn-text {
  font-size: 26rpx;
  color: #333333;
}

/* 产品介绍 */
.intro-section {
  padding: 30rpx;
}

.intro-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

.intro-card .section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.intro-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.intro-item {
  display: flex;
  align-items: flex-start;
}

.intro-item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.intro-item-content {
  flex: 1;
}

.intro-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.intro-item-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx 30rpx;
  color: #999999;
  font-size: 24rpx;
}
